{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Anthropic (Direct)",
      "options": {
        "baseURL": "https://api.anthropic.com/v1",
        "headers": {
          "x-api-key": "${ANTHROPIC_API_KEY}",
          "anthropic-version": "2023-06-01"
        }
      },
      "models": {
        "claude-3.5-sonnet": {
          "name": "claude-3-5-sonnet-20241022",
          "cost": { "input": 0.000003, "output": 0.000015 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-3-opus": {
          "name": "claude-3-opus-20240229",
          "cost": { "input": 0.000015, "output": 0.000075 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    },
    "google": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Google Gemini (Direct)",
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta/openai",
        "headers": {
          "Authorization": "Bearer ${GEMINI_API_KEY}"
        }
      },
      "models": {
        "gemini-3.1-pro": {
          "name": "gemini-3.1-pro",
          "cost": { "input": 0.000002, "output": 0.000012 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "gemini-1.5-pro": {
          "name": "gemini-1.5-pro",
          "cost": { "input": 0.00000125, "output": 0.00000375 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI (Direct)",
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "headers": {
          "Authorization": "Bearer ${OPENAI_API_KEY}"
        }
      },
      "models": {
        "gpt-4o": {
          "name": "gpt-4o",
          "cost": { "input": 0.0000025, "output": 0.00001 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "o1-preview": {
          "name": "o1-preview",
          "cost": { "input": 0.000015, "output": 0.00006 }
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "options": {
        "baseURL": "https://api.minimax.io/v1",
        "headers": {
          "Authorization": "Bearer ${MINIMAX_API_KEY}"
        }
      },
      "models": {
        "m2.7": {
          "name": "MiniMax-M2.7",
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  },
  "model": "anthropic/claude-3.5-sonnet"
}

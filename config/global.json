{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-3-7-sonnet-20250219",
  "small_model": "google/gemini-2.0-flash-lite",
  "instructions": ["~/.opencode/config/global-rules.md", "./MEMORIES.md"],
  "agent": {
    "plan": {
      "model": {
        "providerID": "openai",
        "modelID": "o1-preview"
      },
      "description": "System Architect - Focuses on deep reasoning and planning."
    },
    "build": {
      "model": {
        "providerID": "anthropic",
        "modelID": "claude-3-7-sonnet-20250219"
      }
    },
    "title": {
      "model": {
        "providerID": "minimax-coding-plan",
        "modelID": "MiniMax-M2.7"
      }
    },
    "summary": {
      "model": {
        "providerID": "minimax-coding-plan",
        "modelID": "MiniMax-M2.7"
      }
    },
    "compaction": {
      "model": {
        "providerID": "minimax-coding-plan",
        "modelID": "MiniMax-M2.7"
      }
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "memory": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "google-search": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-search"],
      "env": {
        "GOOGLE_API_KEY": "{env:GOOGLE_SEARCH_API_KEY}",
        "GOOGLE_CSE_ID": "{env:GOOGLE_SEARCH_ENGINE_ID}"
      }
    },
    "sequentialthinking": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequentialthinking"]
    }
  },
  "command": {
    "sync": {
      "description": "Pull latest configuration and sync setup",
      "script": "npm run sync"
    },
    "health": {
      "description": "Run the OpenCode health check",
      "script": "./scripts/check-health.sh"
    },
    "push": {
      "description": "Commit and push setup changes to GitHub",
      "script": "git add . && git commit -m 'Manual setup update' && git push"
    },
    "review": {
      "description": "Perform a deep logic review of staged changes",
      "script": "opencode run --agent reviewer \"Review my staged changes and check for logical errors or style violations.\""
    },
    "brain-init": {
      "description": "Initialize Agentic Stack and Memories for the current project",
      "script": "cp ~/.opencode/config/MEMORIES.template.md ./MEMORIES.md && agentic-stack opencode"
    },
    "private": {
      "description": "Switch to local privacy-mode for sensitive code",
      "script": "opencode run -m omlx/local-privacy \"(Private Session)\""
    }
  },
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax (Direct API)",
      "options": {
        "baseURL": "https://api.minimax.io/v1",
        "headers": {
          "Authorization": "Bearer ${MINIMAX_API_KEY}"
        }
      },
      "models": {
        "m2.7": {
          "name": "MiniMax-M2.7",
          "cost": { "input": 0.0000002, "output": 0.0000008 },
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Privacy Mode (oMLX)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1"
      },
      "models": {
        "local-privacy": {
          "name": "llama-3.2-3b-instruct",
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  }
}

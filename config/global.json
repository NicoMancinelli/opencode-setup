{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nanogpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NanoGPT",
      "options": {
        "baseURL": "https://nano-gpt.com/api/v1",
        "headers": {
          "Authorization": "Bearer ${NANOGPT_API_KEY}"
        }
      },
      "models": {
        "claude-3.5-sonnet": {
          "name": "anthropic/claude-3.5-sonnet",
          "cost": {
            "input": 0.000003,
            "output": 0.000015
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro": {
          "name": "google/gemini-3.1-pro",
          "cost": {
            "input": 0.000002,
            "output": 0.000012
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemini-1.5-pro": {
          "name": "google/gemini-1.5-pro",
          "cost": {
            "input": 0.00000125,
            "output": 0.00000375
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1"
      },
      "models": {
        "gemma4": {
          "name": "gemma4",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "nanogpt/claude-3.5-sonnet"
}
